{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Order Contract",
  "type": "object",
  "properties": {
    "order_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "pending", "confirmed", "preparing", "ready", "in_transit", "delivered", "cancelled", "disputed"]
    },
    "payment_method": {
      "type": "string",
      "enum": ["cash", "card", "digital_wallet"]
    },
    "total_centavos": {
      "type": "integer",
      "minimum": 0,
      "description": "Order total in integer minor money units. For VND, whole dong amounts are stored directly."
    },
    "currency": {
      "type": "string",
      "enum": ["VND", "USD"]
    },
    "created_at": { "type": "string", "description": "UTC ISO 8601 timestamp" },
    "confirmed_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "preparing_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "ready_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "picked_up_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "delivered_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "cancelled_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "disputed_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" },
    "updated_at": { "type": "string", "description": "UTC ISO 8601 timestamp (optional)" }
  },
  "required": ["order_id", "status", "payment_method"]
}
