{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Menu Contract",
  "type": "object",
  "properties": {
    "item_id": { "type": "string", "minLength": 1 },
    "store_id": { "type": "string", "minLength": 1 },
    "price": { "type": "integer", "minimum": 0, "description": "Item price in integer centavos. R-010, R-011." }
  },
  "required": ["item_id", "store_id", "price"]
}
