{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "if [ -d flutter ]; then cd flutter && git pull && cd ..; else git clone https://github.com/flutter/flutter.git -b stable; fi && flutter/bin/flutter config --enable-web && flutter/bin/flutter doctor",
  "buildCommand": "flutter/bin/flutter build web --release --dart-define=SUPABASE_URL=$SUPABASE_URL --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY --dart-define=AUTH_CALLBACK_SCHEME=$AUTH_CALLBACK_SCHEME --dart-define=AUTH_CALLBACK_HOST=$AUTH_CALLBACK_HOST --dart-define=AUTH_CALLBACK_PATH=$AUTH_CALLBACK_PATH --dart-define=ZALO_APP_ID=$ZALO_APP_ID --dart-define=ZALO_REDIRECT_URI=$ZALO_REDIRECT_URI",
  "outputDirectory": "build/web",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
